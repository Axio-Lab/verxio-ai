# Required for production parity mode.
VERXIO_DATABASE_MODE=turso
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Local Docker runtime image built from ./hermes-agent.
VERXIO_HERMES_IMAGE=verxio-hermes-runtime:local
HERMES_UID=10000
HERMES_GID=10000

# Persistent host state: runtime homes, workspaces, artifacts, and local SQLite fallback.
# Local dev: leave unset (uses ./.verxio next to this repo).
# Production: set to an absolute path on persistent disk, e.g. /srv/verxio
# VERXIO_STATE_DIR=/srv/verxio

# Optional override for Hermes runtime bind mounts. Defaults to ${VERXIO_STATE_DIR}/runtimes
# or ${PWD}/.verxio/runtimes when VERXIO_STATE_DIR is unset.
# VERXIO_RUNTIME_DOCKER_ROOT=/absolute/path/to/.verxio/runtimes
VERXIO_RUNTIME_CONNECT_HOST=host.docker.internal
VERXIO_RUNTIME_PUBLISH_HOST=127.0.0.1

# Use true only behind HTTPS.
VERXIO_COOKIE_SECURE=false
VERXIO_CORS_ORIGINS=https://your-verxio-web.example

# Auth code security and email delivery.
# Set VERXIO_AUTH_CODE_SECRET to a long random value in production.
VERXIO_AUTH_CODE_SECRET=change-this-long-random-secret
VERXIO_AUTH_CODE_TTL_MINUTES=10
VERXIO_AUTH_CODE_MAX_ATTEMPTS=5
VERXIO_SMTP_HOST=smtp.example.com
VERXIO_SMTP_PORT=587
VERXIO_SMTP_USERNAME=your-smtp-username
VERXIO_SMTP_PASSWORD=your-smtp-password
VERXIO_SMTP_FROM=Verxio <no-reply@example.com>
VERXIO_SMTP_TLS=true

# Verxio Hosted inference (Qwen via DashScope only).
# Injected into runtime containers when users select Verxio Hosted.
# BYOK keys for OpenAI, Anthropic, etc. stay in each Hermes runtime .env.
VERXIO_HOSTED_QWEN_API_KEY=

# Optional operator override for the hosted Qwen model ID (DashScope upstream slug).
# Change this and restart verxio-api to roll out a new default without a code deploy.
VERXIO_HOSTED_QWEN_MODEL=qwen3.6-plus
VERXIO_DEFAULT_MONTHLY_CREDIT_USD=0

# Enables the full Composio toolkits catalog and per-tool previews.
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_API_BASE_URL=https://backend.composio.dev/api/v3
COMPOSIO_TOOLS_API_BASE_URL=https://backend.composio.dev/api/v3.1

# Pulse (operator / deployment only). End users connect Instagram, Messenger, and
# WhatsApp in the app under Pulse → Channels. Meta requires a public HTTPS webhook URL in production.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=change-this-meta-webhook-token
META_GRAPH_VERSION=v20.0
VERXIO_PULSE_SECRET=change-this-long-random-pulse-secret
