{
  "name": "verxio-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Verxio AI monorepo — Hermes runtime with Verxio API and web UI.",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "desktop:build": "npm run build --prefix verxio-desktop",
    "desktop:dev": "npm run dev --prefix verxio-desktop",
    "desktop:pack": "npm run pack --prefix verxio-desktop",
    "desktop:start": "npm run start --prefix verxio-desktop",
    "api:test": "cd verxio-api && uv run pytest",
    "fmt": "prettier --write README.md package.json 'verxio-web/src/**/*.{ts,tsx}' 'verxio-web/packages/shared/**/*.{ts,tsx}' 'verxio-web/vite.config.ts' 'verxio-desktop/electron/**/*.{js,cjs}' 'verxio-desktop/scripts/**/*.{js,cjs}' 'verxio-desktop/package.json' 'verxio-desktop/README.md'",
    "format": "npm run fmt",
    "format:check": "prettier --check README.md package.json 'verxio-web/src/**/*.{ts,tsx}' 'verxio-web/packages/shared/**/*.{ts,tsx}' 'verxio-web/vite.config.ts' 'verxio-desktop/electron/**/*.{js,cjs}' 'verxio-desktop/scripts/**/*.{js,cjs}' 'verxio-desktop/package.json' 'verxio-desktop/README.md'",
    "install:desktop": "npm ci --prefix verxio-desktop",
    "install:web": "npm ci --prefix verxio-web",
    "preci:web": "npm run install:web",
    "ci:api": "npm run api:test",
    "ci:desktop": "npm run ci --prefix verxio-desktop",
    "ci:web": "npm run ci --prefix verxio-web",
    "ci": "npm run fmt && npm run format:check && npm run ci:api && npm run ci:web && npm run ci:desktop",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
